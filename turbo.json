{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["AI_GATEWAY_API_KEY"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "AI_GATEWAY_API_KEY",
        "AI_GATEWAY_BASE_URL",
        "AI_GATEWAY_MODEL",
        "VERCEL_AI_GATEWAY_API_KEY"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
